GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_FALLBACK_MODEL=

# Tavily (web research) - https://tavily.com  (1,000 free credits)
TAVILY_API_KEY=

# SLNG (voice) - https://app.slng.ai  (4 EUR free credits)
SLNG_API_KEY=

# Mubit / Minima (cheapest-model routing) - https://console.mubit.ai
