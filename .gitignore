# Secrets - NEVER commit. A leaked Gemini key auto-kills the whole temp project,
# and a later "delete the key" commit does NOT help: it stays in git history.
.env
*.key
secrets/
# Baked-in local API keys for the extension (gitignored). Use config.local.example.js as the template.
extension/config.local.js

# Python
__pycache__/
*.pyc
.venv/
venv/

# Logs / local
*.log
.DS_Store
